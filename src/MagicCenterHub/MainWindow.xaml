<Window x:Class="MagicCenterHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MagicCenterHub"
        xmlns:utils="clr-namespace:MagicCenterHub.Utils"
        Title="MagicCenterHub" Width="1428" Height="284"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        Loaded="Window_Loaded" Closing="Window_Closing" MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <utils:PercentToWidthConverter x:Key="PercentToWidthConverter" />
        <Style x:Key="UsageBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="26" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Background" Value="#444" />
            <Setter Property="Foreground" Value="#6FCF6F" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <Border x:Name="PART_Track" CornerRadius="5">
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="5"
                                        Background="{TemplateBinding Foreground}" />
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TempBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="26" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Background" Value="#444" />
            <Setter Property="Foreground" Value="#6FCF6F" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <Border x:Name="PART_Track" CornerRadius="5">
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="5"
                                        Background="{TemplateBinding Foreground}" />
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="#2A2A2E" CornerRadius="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧 LED 灯柱 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- 红灯 -->
                    <Grid Width="60" Height="60" Margin="0,0,0,20">
                        <Ellipse Fill="#C02020" />
                        <Ellipse Width="48" Height="48">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{Binding LedRed}" />
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="24" Height="24" Fill="#FFAAAA" Opacity="0.7" />
                    </Grid>
                    <!-- 黄灯 -->
                    <Grid Width="60" Height="60" Margin="0,0,0,20">
                        <Ellipse Fill="#A06000" />
                        <Ellipse Width="48" Height="48">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{Binding LedYellow}" />
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="24" Height="24" Fill="#FFD890" Opacity="0.7" />
                    </Grid>
                    <!-- 绿灯 -->
                    <Grid Width="60" Height="60">
                        <Ellipse Fill="#116611" />
                        <Ellipse Width="48" Height="48">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{Binding LedGreen}" />
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="24" Height="24" Fill="#A0F0A0" Opacity="0.7" />
                    </Grid>
                </StackPanel>
                <!-- HWiNFO 状态 - 底部 -->
                <TextBlock Grid.Row="1" Text="{Binding HwInfoStatusText}" Foreground="{Binding HwInfoStatusColor}"
                           FontFamily="Courier New" FontSize="11" HorizontalAlignment="Center"
                           Margin="0,0,0,8" />
            </Grid>

            <!-- 右侧面板区域 -->
            <Grid Grid.Column="1" Margin="0,8,8,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>

                <!-- CPU 面板 -->
                <Border Grid.Column="0" Background="#333338" CornerRadius="10" Padding="16,8" Margin="0,10,0,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Path Width="28" Height="30" Fill="#7DD4D4" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"
                                  Data="M22,9V7H20V5A2,2 0 0,0 18,3H15V1H13V3H11V1H9V3H6A2,2 0 0,0 4,5V7H2V9H4V11H2V13H4V15H2V17H4V19A2,2 0 0,0 6,21H18A2,2 0 0,0 20,19V17H22V15H20V13H22V11H20V9H22M18,19H6V5H18V19M10,13H8V11H10V13M14,13H16V11H14V13Z" />
                            <TextBlock Text="CPU" FontFamily="Courier New" FontSize="30" FontWeight="Bold"
                                       Foreground="#7DD4D4" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="CPU 使用率" FontFamily="Courier New" FontSize="14" Foreground="#D3D0D0" Margin="0,4,0,2" />
                        <TextBlock Text="{Binding CpuUsageText}" FontFamily="Courier New" FontSize="24" FontWeight="Bold"
                                   Foreground="{Binding CpuUsageColor}" Margin="0,0,0,3" />
                        <ProgressBar Style="{StaticResource UsageBar}" Value="{Binding CpuUsagePercent}"
                                     Foreground="{Binding CpuUsageBarColor}" />
                        <TextBlock Text="CPU 温度" FontFamily="Courier New" FontSize="14" Foreground="#D3D0D0" Margin="0,18,0,2" />
                        <TextBlock Text="{Binding CpuTempText}" FontFamily="Courier New" FontSize="24" FontWeight="Bold"
                                   Foreground="{Binding CpuTempColor}" Margin="0,0,0,3" />
                        <ProgressBar Style="{StaticResource TempBar}" Value="{Binding CpuTempPercent}"
                                     Foreground="{Binding CpuTempBarColor}" />
                    </StackPanel>
                </Border>

                <!-- GPU 面板 -->
                <Border Grid.Column="2" Background="#333338" CornerRadius="10" Padding="16,8" Margin="0,10,0,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Path Width="28" Height="30" Fill="#7DD4D4" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"
                                  Data="M2,6H22V18H2V6M4,8V16H20V8H4M6,10H8V12H10V14H8V16H6V14H4V12H6V10M14,10A2,2 0 0,1 16,12A2,2 0 0,1 14,14A2,2 0 0,1 12,12A2,2 0 0,1 14,10M17,11A1,1 0 0,1 18,12A1,1 0 0,1 17,13A1,1 0 0,1 16,12A1,1 0 0,1 17,11Z" />
                            <TextBlock Text="GPU" FontFamily="Courier New" FontSize="30" FontWeight="Bold"
                                       Foreground="#7DD4D4" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="GPU 使用率" FontFamily="Courier New" FontSize="14" Foreground="#D3D0D0" Margin="0,4,0,2" />
                        <TextBlock Text="{Binding GpuUsageText}" FontFamily="Courier New" FontSize="24" FontWeight="Bold"
                                   Foreground="{Binding GpuUsageColor}" Margin="0,0,0,3" />
                        <ProgressBar Style="{StaticResource UsageBar}" Value="{Binding GpuUsagePercent}"
                                     Foreground="{Binding GpuUsageBarColor}" />
                        <TextBlock Text="GPU 温度" FontFamily="Courier New" FontSize="14" Foreground="#D3D0D0" Margin="0,18,0,2" />
                        <TextBlock Text="{Binding GpuTempText}" FontFamily="Courier New" FontSize="24" FontWeight="Bold"
                                   Foreground="{Binding GpuTempColor}" Margin="0,0,0,3" />
                        <ProgressBar Style="{StaticResource TempBar}" Value="{Binding GpuTempPercent}"
                                     Foreground="{Binding GpuTempBarColor}" />
                    </StackPanel>
                </Border>

                <!-- 内存、电池 -->
                <Border Grid.Column="4" Background="#333338" CornerRadius="10" Padding="16,8" Margin="0,10,0,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Path Width="28" Height="30" Fill="#7DD4D4" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"
                                  Data="M4,1H20A1,1 0 0,1 21,2V6A1,1 0 0,1 20,7H4A1,1 0 0,1 3,6V2A1,1 0 0,1 4,1M4,9H20A1,1 0 0,1 21,10V14A1,1 0 0,1 20,15H4A1,1 0 0,1 3,14V10A1,1 0 0,1 4,9M4,17H20A1,1 0 0,1 21,18V22A1,1 0 0,1 20,23H4A1,1 0 0,1 3,22V18A1,1 0 0,1 4,17M7,4V5H17V4H7M7,12V13H17V12H7M7,20V21H17V20H7Z" />
                            <TextBlock Text="RAM/BATT" FontFamily="Courier New" FontSize="20" FontWeight="Bold"
                                       Foreground="#7DD4D4" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="内存占用" FontFamily="Courier New" FontSize="14" Foreground="#D3D0D0" Margin="0,8,0,2" />
                        <TextBlock Text="{Binding MemoryText}" FontFamily="Courier New" FontSize="24" FontWeight="Bold"
                                   Foreground="{Binding MemoryColor}" Margin="0,0,0,3" />
                        <ProgressBar Style="{StaticResource UsageBar}" Value="{Binding MemoryPercent}"
                                     Foreground="{Binding MemoryBarColor}" />
                        <TextBlock Text="电池功耗" FontFamily="Courier New" FontSize="14" Foreground="#D3D0D0" Margin="0,18,0,2" />
                        <TextBlock Text="{Binding BatteryText}" FontFamily="Courier New" FontSize="24" FontWeight="Bold"
                                   Foreground="{Binding BatteryColor}" Margin="0,0,0,3" />
                        <ProgressBar Style="{StaticResource TempBar}" Value="{Binding BatteryPercent}"
                                     Foreground="{Binding BatteryBarColor}" />
                    </StackPanel>
                </Border>

                <!-- 磁盘 + 网络面板 -->
                <Grid Grid.Column="6" Margin="0,10,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 磁盘子面板 -->
                    <Border Grid.Row="0" Background="#3C3C42" CornerRadius="8" Padding="12,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Path Width="25" Height="25" Fill="#7DD4D4" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"
                                      Data="M12,3C7.58,3 4,4.79 4,7V17C4,19.21 7.58,21 12,21C16.42,21 20,19.21 20,17V7C20,4.79 16.42,3 12,3M12,5C16.14,5 18,6.56 18,7C18,7.44 16.14,9 12,9C7.86,9 6,7.44 6,7C6,6.56 7.86,5 12,5M12,19C7.86,19 6,17.44 6,17V13.28C7.36,14.5 9.58,15.5 12,15.5C14.42,15.5 16.64,14.5 18,13.28V17C18,17.44 16.14,19 12,19Z" />
                                <TextBlock Text="Disk" FontFamily="Courier New" FontSize="25" FontWeight="Bold"
                                           Foreground="#7DD4D4" VerticalAlignment="Center" />
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="读取" FontFamily="Courier New" FontSize="16" Foreground="#D3D0D0" Margin="2,10,0,2" />
                                    <TextBlock Text="{Binding DiskReadText}" FontFamily="Courier New" FontSize="22" FontWeight="Bold" Margin="2,4,0,2"
                                               Foreground="#6FCF6F" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Text="写入" FontFamily="Courier New" FontSize="16" Foreground="#D3D0D0" Margin="0,10,0,2" />
                                    <TextBlock Text="{Binding DiskWriteText}" FontFamily="Courier New" FontSize="22" FontWeight="Bold" Margin="2,4,0,2"
                                               Foreground="#F0A840" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 网络子面板 -->
                    <Border Grid.Row="2" Background="#3C3C42" CornerRadius="8" Padding="12,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Path Width="25" Height="25" Fill="#7DD4D4" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"
                                      Data="M12,21L15.6,16.2C14.6,15.45 13.35,15 12,15C10.65,15 9.4,15.45 8.4,16.2L12,21M12,3C7.95,3 4.21,4.34 1.5,6.5L3,8C5.26,6.07 8.47,5 12,5C15.53,5 18.74,6.07 21,8L22.5,6.5C19.79,4.34 16.05,3 12,3M12,9C9.3,9 6.81,9.99 4.8,11.6L6.2,13C7.76,11.72 9.78,11 12,11C14.22,11 16.24,11.72 17.8,13L19.2,11.6C17.19,9.99 14.7,9 12,9Z" />
                                <TextBlock Text="Network" FontFamily="Courier New" FontSize="25" FontWeight="Bold"
                                           Foreground="#7DD4D4" VerticalAlignment="Center" />
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="上传" FontFamily="Courier New" FontSize="16" Foreground="#D3D0D0" Margin="2,10,0,2" />
                                    <TextBlock Text="{Binding NetUpText}" FontFamily="Courier New" FontSize="22" FontWeight="Bold" Margin="2,4,0,2"
                                               Foreground="#6FCF6F" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Text="下载" FontFamily="Courier New" FontSize="16" Foreground="#D3D0D0" Margin="0,10,0,2" />
                                    <TextBlock Text="{Binding NetDownText}" FontFamily="Courier New" FontSize="22" FontWeight="Bold" Margin="2,4,0,2"
                                               Foreground="#50D0C0" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>